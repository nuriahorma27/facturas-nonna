{
  "name": "Facturas - Subir a Drive",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "facturas-drive-upload",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "n1",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "facturas-drive-upload"
    },
    {
      "parameters": {
        "jsCode": "const b = $input.first().json?.body ?? $input.first().json;\nconst trim = b.trimestre ?? 'T1';\nconst anyo = String(b.anyo ?? new Date().getFullYear());\nconst tipo = b.tipo ?? 'gasto';\nreturn [{\n  json: {\n    fileBase64: b.file,\n    fileName: b.nombre ?? ('factura_' + Date.now() + '.pdf'),\n    mimeType: b.mimeType ?? 'application/pdf',\n    trimFolder: `${trim} - ${anyo}`,\n    tipoFolder: tipo === 'ingreso' ? 'Ingresos' : 'Gastos',\n    rootId: '1_-4IPitaopGpH6XCfcvOIhcB6c9V1cM5'\n  }\n}];"
      },
      "id": "n2",
      "name": "Parsear datos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://www.googleapis.com/drive/v3/files",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleDriveOAuth2Api",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "q",
              "value": "={{ \"'\" + $json.rootId + \"' in parents and name = '\" + $json.trimFolder + \"' and mimeType = 'application/vnd.google-apps.folder' and trashed = false\" }}"
            },
            { "name": "fields", "value": "files(id,name)" },
            { "name": "pageSize", "value": "1" }
          ]
        },
        "options": {}
      },
      "id": "n3",
      "name": "Buscar carpeta trimestre",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [680, 300]
    },
    {
      "parameters": {
        "jsCode": "const res = $input.first().json;\nconst data = $('Parsear datos').first().json;\nconst trimFolderId = (res.files && res.files.length > 0) ? res.files[0].id : null;\nreturn [{ json: { ...data, trimFolderId } }];"
      },
      "id": "n4",
      "name": "Extraer ID trimestre",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "cond-trim",
              "leftValue": "={{ $json.trimFolderId }}",
              "rightValue": "",
              "operator": { "type": "string", "operation": "isEmpty" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "n5",
      "name": "¿Crear carpeta trimestre?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://www.googleapis.com/drive/v3/files",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleDriveOAuth2Api",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "Content-Type", "value": "application/json" }]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ name: $json.trimFolder, mimeType: 'application/vnd.google-apps.folder', parents: [$json.rootId] }) }}",
        "options": {}
      },
      "id": "n6",
      "name": "Crear carpeta trimestre",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1340, 160]
    },
    {
      "parameters": {
        "jsCode": "const created = $input.first().json;\nconst data = $('Parsear datos').first().json;\nreturn [{ json: { ...data, trimFolderId: created.id } }];"
      },
