      "parameters": {
        "method": "POST",
        "url": "https://www.googleapis.com/drive/v3/files",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleDriveOAuth2Api",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "Content-Type", "value": "application/json" }]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ name: $json.fileName, mimeType: $json.mimeType, parents: [$json.tipoFolderId] }) }}",
        "options": {}
      },
      "id": "n13",
      "name": "Crear metadata archivo",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [2880, 300]
    },
    {
      "parameters": {
        "jsCode": "const meta = $input.first().json;\nconst src = $('Parsear datos').first().json;\nconst buf = Buffer.from(src.fileBase64, 'base64');\nconst binaryData = await $helpers.prepareBinaryData(buf, src.fileName, src.mimeType);\nreturn [{\n  json: { ...src, fileId: meta.id },\n  binary: { data: binaryData }\n}];"
      },
      "id": "n14",
      "name": "Preparar binario",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3100, 300]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{ 'https://www.googleapis.com/upload/drive/v3/files/' + $json.fileId + '?uploadType=media' }}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleDriveOAuth2Api",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "Content-Type", "value": "={{ $json.mimeType }}" }]
        },
        "sendBody": true,
        "contentType": "binaryData",
        "inputDataFieldName": "data",
        "options": {}
      },
      "id": "n15",
      "name": "Subir contenido archivo",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [3320, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ 'https://www.googleapis.com/drive/v3/files/' + $json.id + '/permissions' }}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleDriveOAuth2Api",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "Content-Type", "value": "application/json" }]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"type\":\"anyone\",\"role\":\"reader\"}",
        "options": {}
      },
      "id": "n16",
      "name": "Compartir archivo",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [3540, 300]
    },
    {
      "parameters": {
        "jsCode": "const fileId = $('Preparar binario').first().json.fileId;\nreturn [{\n  json: {\n    success: true,\n    fileId,\n    fileUrl: `https://drive.google.com/file/d/${fileId}/view`\n  }\n}];"
      },
      "id": "n17",
